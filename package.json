{
  "name": "dynamic-db-mcp",
  "version": "1.0.0",
  "description": "Dynamic database MCP server - MySQL and PostgreSQL with runtime database switching",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dynamic-db-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "database",
    "mysql",
    "postgresql",
    "sql",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.1",
    "mysql2": "^3.14.0",
    "pg": "^8.14.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.14",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}